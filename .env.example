# =====================================================================
# AgentVault — root .env (shared across services where applicable)
# Copy to `.env` and fill in. Service-specific overrides live in each
# package's own .env(.local).example.
# =====================================================================

# --- Solana ----------------------------------------------------------
SOLANA_NETWORK=devnet                          # devnet | mainnet-beta
SOLANA_RPC_URL=https://api.devnet.solana.com   # or Helius
AGENTVAULT_PROGRAM_ID=                         # filled after `anchor deploy`
USDC_MINT=4zMMC9srt5Ri5X14GAgXhaHii3GnPAEERYPJgZJDncDU
TREASURY_WALLET=

# --- Supabase --------------------------------------------------------
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxx.supabase.co:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...               # backend-only, never expose to frontend

# --- Redis (Railway plugin) -----------------------------------------
REDIS_URL=redis://default:PASSWORD@host:6379

# --- Arweave / Bundlr -----------------------------------------------
BUNDLR_NETWORK=https://node1.bundlr.network
BUNDLR_KEYPAIR=                                # base58-encoded Solana keypair

# --- x402 ------------------------------------------------------------
X402_FACILITATOR_URL=https://facilitator.payai.network
X402_TREASURY=

# --- Worker (RunPod) -------------------------------------------------
WORKER_URL=https://worker.agentvault.xyz
WORKER_API_KEY=

# --- Qwen runtime (RunPod) ------------------------------------------
VLLM_ENDPOINT=https://your-runpod.proxy.runpod.net
LMCACHE_REMOTE_URL=https://api.agentvault.xyz/v1/lmcache
